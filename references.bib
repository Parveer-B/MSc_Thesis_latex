@article{newman_when_2006,
	title = {When will the {Antarctic} ozone hole recover?},
	volume = {33},
	copyright = {Copyright 2006 by the American Geophysical Union.},
	issn = {1944-8007},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1029/2005GL025232},
	doi = {10.1029/2005GL025232},
	abstract = {The Antarctic ozone hole demonstrates large-scale, man-made affects on our atmosphere. Surface observations now show that human produced ozone-depleting substances (ODSs) are declining. The ozone hole should soon start to diminish because of this decline. We demonstrate a parametric model of ozone hole area that is based upon a new algorithm for estimating chlorine and bromine levels over Antarctica and late spring Antarctic stratospheric temperatures. This model explains 95\% of the ozone hole area's variance. We then use future ODS levels to predict ozone hole recovery. Full recovery to 1980 levels will occur around 2068 and the area will very slowly decline between 2001 and 2017. Detection of a statistically significant decrease of area will not occur until about 2024. We further show that nominal Antarctic stratospheric greenhouse gas forced temperature change should have a small impact on the ozone hole.},
	language = {en},
	number = {12},
	urldate = {2026-03-10},
	journal = {Geophysical Research Letters},
	author = {Newman, Paul A. and Nash, Eric R. and Kawa, S. Randolph and Montzka, Stephen A. and Schauffler, Sue M.},
	year = {2006},
	note = {\_eprint: https://agupubs.onlinelibrary.wiley.com/doi/pdf/10.1029/2005GL025232},
	file = {Full Text PDF:C\:\\Users\\Lenovo\\Zotero\\storage\\WZ796LDT\\Newman et al. - 2006 - When will the Antarctic ozone hole recover.pdf:application/pdf;Snapshot:C\:\\Users\\Lenovo\\Zotero\\storage\\LAQ4IC4U\\2005GL025232.html:text/html},
}

@article{wohltmann_chemical_2024,
	title = {The {Chemical} {Effect} of {Increased} {Water} {Vapor} {From} the {Hunga} {Tonga}-{Hunga} {Ha}'apai {Eruption} on the {Antarctic} {Ozone} {Hole}},
	volume = {51},
	copyright = {© 2024. The Authors.},
	issn = {1944-8007},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1029/2023GL106980},
	doi = {10.1029/2023GL106980},
	abstract = {The eruption of the Hunga Tonga-Hunga Ha'apai volcano on 15 January 2022 was one of the most explosive eruptions of the last decades. The amount of water vapor injected into the stratosphere was unprecedented in the observational record, increasing the stratospheric water vapor burden by about 10\%. Using model runs from the ATLAS chemistry and transport model and Microwave Limb Sounder (MLS) satellite observations, we show that while 20\%–40\% more water vapor than usual was entrained into the Antarctic polar vortex in 2023 as it formed, the direct chemical effect of the increased water vapor on Antarctic ozone depletion in June through October was minor (less than 4 DU). This is because low temperatures in the vortex, as occur every year in the Antarctic, limit water vapor to the saturation pressure and thus reset any anomalies through the process of dehydration before they can affect ozone loss.},
	language = {en},
	number = {4},
	urldate = {2026-03-10},
	journal = {Geophysical Research Letters},
	author = {Wohltmann, Ingo and Santee, Michelle L. and Manney, Gloria L. and Millán, Luis F.},
	year = {2024},
	note = {\_eprint: https://agupubs.onlinelibrary.wiley.com/doi/pdf/10.1029/2023GL106980},
	keywords = {stratosphere, water vapor, Hunga Tonga-Hunga Ha'apai, ozone chemistry, ozone hole},
	pages = {e2023GL106980},
	annote = {e2023GL106980 2023GL106980},
	file = {Full Text PDF:C\:\\Users\\Lenovo\\Zotero\\storage\\HCSSNIEW\\Wohltmann et al. - 2024 - The Chemical Effect of Increased Water Vapor From the Hunga Tonga-Hunga Ha'apai Eruption on the Anta.pdf:application/pdf},
}

@article{solomon_emergence_2016,
	title = {Emergence of healing in the {Antarctic} ozone layer},
	volume = {353},
	url = {https://www.science.org/doi/10.1126/science.aae0061},
	doi = {10.1126/science.aae0061},
	abstract = {Industrial chlorofluorocarbons that cause ozone depletion have been phased out under the Montreal Protocol. A chemically driven increase in polar ozone (or “healing”) is expected in response to this historic agreement. Observations and model calculations together indicate that healing of the Antarctic ozone layer has now begun to occur during the month of September. Fingerprints of September healing since 2000 include (i) increases in ozone column amounts, (ii) changes in the vertical profile of ozone concentration, and (iii) decreases in the areal extent of the ozone hole. Along with chemistry, dynamical and temperature changes have contributed to the healing but could represent feedbacks to chemistry. Volcanic eruptions have episodically interfered with healing, particularly during 2015, when a record October ozone hole occurred after the Calbuco eruption.},
	number = {6296},
	urldate = {2026-03-10},
	journal = {Science},
	publisher = {American Association for the Advancement of Science},
	author = {Solomon, Susan and Ivy, Diane J. and Kinnison, Doug and Mills, Michael J. and Neely, Ryan R. and Schmidt, Anja},
	month = jul,
	year = {2016},
	pages = {269--274},
	file = {Full Text PDF:C\:\\Users\\Lenovo\\Zotero\\storage\\ZPCX5HJ2\\Solomon et al. - 2016 - Emergence of healing in the Antarctic ozone layer.pdf:application/pdf},
}

